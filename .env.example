# ===========================================
# Eggologic Hedera — Environment Configuration
# ===========================================

# --- Hedera Network ---
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxx
HEDERA_OPERATOR_KEY=302e020100300506032b6570...

# --- Hedera Token IDs (created by setup-testnet.js) ---
EGGOCOINS_TOKEN_ID=0.0.xxxxx
CARBONCOIN_TOKEN_ID=0.0.xxxxx
TREASURY_ACCOUNT_ID=0.0.xxxxx

# --- HCS Topic IDs (created by setup-testnet.js) ---
HCS_TOPIC_DELIVERIES=0.0.xxxxx
HCS_TOPIC_BATCHES=0.0.xxxxx
HCS_TOPIC_PRODUCTION=0.0.xxxxx

# --- Supplier Accounts (HashPack Demo) ---
SUPPLIER_ACCOUNT_ID=
SUPPLIER_EVM_ADDRESS=
SUPPLIER_PRIVATE_KEY=
SUPPLIER_MODE=custodial

# --- Guardian ---
GUARDIAN_URL=http://localhost:3000
GUARDIAN_POLICY_ID=your_policy_id
GUARDIAN_USERNAME=eggologic_operator
GUARDIAN_PASSWORD=secure_password

# --- Google Sheets ---
GOOGLE_SPREADSHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----"

# --- Database ---
DATABASE_URL=postgresql://eggologic:password@localhost:5432/eggologic

# --- Redis (for BullMQ job queue) ---
REDIS_URL=redis://localhost:6379

# --- Application ---
PORT=4000
NODE_ENV=development
POLLING_INTERVAL_MINUTES=5
VITE_API_URL=http://localhost:4000
DEMO_MODE=true

# --- Carbon Credit Configuration ---
CARBON_THRESHOLD_KG=1000
CONSERVATIVE_FACTOR=0.70
